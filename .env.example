# ==========================================
# Shopify 应用配置
# ==========================================
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=
SHOPIFY_REDIRECT_URI=
SHOPIFY_API_VERSION=2026-04

# ==========================================
# 服务器配置
# ==========================================
PORT=3001
NODE_ENV=production

# ==========================================
# MySQL 数据库配置
# ==========================================
DATABASE_URL=mysql://user:password@host:port/database

# ==========================================
# Session / JWT 密钥
# ==========================================
SESSION_SECRET=your_random_secret_key_here

# ==========================================
# 前端脚本配置
# ==========================================
WIDGET_POSITION=bottom-right
