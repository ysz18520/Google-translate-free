generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// 已授权的 Shopify 店铺信息
model Shop {
  id            Int      @id @default(autoincrement())
  shopDomain    String   @unique @map("shop_domain")
  accessToken   String   @map("access_token")
  scope         String?
  email         String?
  name          String?
  plan          String?
  isActive      Boolean  @default(true) @map("is_active")

  // === 多应用凭证支持（v2.1.0）：每个店铺可绑定独立的 Custom App 凭证 ===
  apiKey        String?  @map("api_key")
  apiSecret     String?  @map("api_secret")
  isAdmin       Boolean  @default(false) @map("is_admin")

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  settings      ShopSetting?

  @@map("shops")
}

// 店铺设置
model ShopSetting {
  id               Int      @id @default(autoincrement())
  shopId           Int      @unique @map("shop_id")
  widgetPosition   String   @default("bottom-right") @map("widget_position")
  widgetColor      String   @default("#1976d2") @map("widget_color")

  // === 语言配置优化（v1.1.0） ===
  defaultLanguage  String   @default("en") @map("default_language")       // 店主设置的默认语言
  autoDetect       Boolean  @default(false) @map("auto_detect")           // 是否自动检测浏览器语言
  enabledLanguages String   @default("en,es,fr,ara,zh") @map("enabled_languages") // 启用的语言列表
  customLanguages  String?  @map("custom_languages") @db.Text             // 自定义语言 JSON 数组

  // === 翻译引擎配置（配置化翻译引擎 v1.2.0） ===
  translateProvider  String?  @map("translate_provider")  // baidu / openai-compat
  translateApiKey    String?  @map("translate_api_key")    // AES 加密存储
  translateApiSecret String?  @map("translate_api_secret") // 百度需要 secret
  translateModel     String?  @map("translate_model")      // 模型名（AI 提供商需要）
  translateEndpoint  String?  @map("translate_endpoint")   // 自定义 API 地址

  // 保留旧字段兼容（后续可清理）
  autoTranslate   Boolean  @default(false) @map("auto_translate")
  activeLanguages String   @default("en,es,fr,ara,zh") @map("active_languages")
  debugToken      String?  @map("debug_token") // 店主调试授权 token
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@map("shop_settings")
}

